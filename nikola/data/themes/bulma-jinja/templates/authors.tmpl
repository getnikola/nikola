{#  -*- coding: utf-8 -*- #}
{% extends 'base.tmpl' %}
{% import 'feeds_translations_helper.tmpl' as feeds_translations with context %}

{% block extra_head %}
    {{ feeds_translations.head(kind=kind, feeds=False) }}
{% endblock %}

{% block content %}
{% if items %}
    <h2 class="title">{{ messages("Authors") }}</h2>
    <div class="metadata">
        {{ feeds_translations.translation_link(kind) }}
    </div>
{% endif %}
{% if items %}
    <div class="tags">
    {% for text, link in items %}
        {% if text not in hidden_authors %}
            <a class="tag is-info" href="{{ link }}">{{ text|e }}</a>
        {% endif %}
    {% endfor %}
    </div>
{% endif %}
{% endblock %}
